# OHDSI Community Intelligence Platform - Environment Variables
# Copy this file to .env and update with your values

# Environment
NODE_ENV=development
ENVIRONMENT=development

# Database Configuration
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_USER=ohdsi_user
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=ohdsi_dashboard

# Elasticsearch Configuration
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_TIMEOUT=30
ELASTIC_PASSWORD=dev-elastic-password

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
SECRET_KEY=change_this_to_a_random_secret_key_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin Bootstrap (creates admin user on first startup)
ADMIN_EMAIL=admin@ohdsi.org
ADMIN_PASSWORD=change_this_strong_password

# API Configuration
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Frontend Configuration
# For development: use absolute localhost URLs
# For production behind nginx/CDN: use relative paths (/api, /graphql)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql

# Application URLs (for SSO callbacks)
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ML Classifier Configuration
CLASSIFIER_THRESHOLD=0.7
CLASSIFIER_BATCH_SIZE=100

# NCBI Entrez (for PubMed integration)
NCBI_ENTREZ_EMAIL=your_email@example.com
NCBI_ENTREZ_API_KEY=

# Multi-Source Content Pipeline API Keys
# GitHub Personal Access Token (optional, but recommended to avoid rate limits)
# Create at: https://github.com/settings/tokens
# Required scopes: public_repo, read:org
GITHUB_TOKEN=

# YouTube Data API v3 Key (optional, for YouTube content)
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# OpenAI API Key (optional, for AI enhancement features)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Discourse API Key (optional, only needed for private forums)
# Get from your Discourse admin panel
DISCOURSE_API_KEY=

# ==========================================
# SSO Configuration (Optional)
# Enables single sign-on with external providers
# ==========================================

# Google OAuth2
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable Google+ API
# 4. Create OAuth 2.0 credentials
# 5. Add authorized redirect URI: http://localhost:8000/api/sso/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# 1. Go to https://github.com/settings/developers
# 2. Create a new OAuth App
# 3. Set Authorization callback URL: http://localhost:8000/api/sso/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft Azure AD (Optional - for enterprise SSO)
# 1. Go to https://portal.azure.com/
# 2. Navigate to Azure Active Directory > App registrations
# 3. Create new registration
# 4. Add redirect URI: http://localhost:8000/api/sso/azure/callback
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ORCID OAuth (Optional - for researcher authentication)
# 1. Go to https://orcid.org/developer-tools
# 2. Register your application
# 3. Set redirect URI: http://localhost:8000/api/sso/orcid/callback
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Monitoring (optional)
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=
DATADOG_API_KEY=

# AWS Configuration (for production deployment)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Email Configuration (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@ohdsi.org