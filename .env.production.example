# ===================================================================
# OHDSI Dashboard - Production Environment Configuration
# ===================================================================
# Copy this file to .env.production and fill in your values
# NEVER commit .env.production to version control!

# Domain Configuration
DOMAIN=ohdsi-dashboard.yourdomain.com
NEXT_PUBLIC_API_URL=https://ohdsi-dashboard.yourdomain.com/api
NEXT_PUBLIC_GRAPHQL_URL=https://ohdsi-dashboard.yourdomain.com/graphql

# Database Configuration
POSTGRES_DB=ohdsi_dashboard
POSTGRES_USER=ohdsi_prod_user
POSTGRES_PASSWORD=<GENERATE_STRONG_PASSWORD>  # Use: openssl rand -base64 32

# Elasticsearch Configuration
ELASTIC_PASSWORD=<GENERATE_STRONG_PASSWORD>  # Use: openssl rand -base64 32

# Redis Configuration
REDIS_PASSWORD=<GENERATE_STRONG_PASSWORD>  # Use: openssl rand -base64 32

# Application Security
SECRET_KEY=<GENERATE_SECRET_KEY>  # Use: openssl rand -hex 64
JWT_SECRET=<GENERATE_JWT_SECRET>  # Use: openssl rand -hex 64
ALLOWED_HOSTS=ohdsi-dashboard.yourdomain.com,www.ohdsi-dashboard.yourdomain.com
CORS_ORIGINS=https://ohdsi-dashboard.yourdomain.com,https://www.ohdsi-dashboard.yourdomain.com

# API Keys (External Services)
OPENAI_API_KEY=your-openai-api-key-here
GITHUB_TOKEN=your-github-token-here
YOUTUBE_API_KEY=your-youtube-api-key-here
DISCOURSE_API_KEY=  # Optional
NCBI_ENTREZ_EMAIL=your-email@institution.edu
NCBI_ENTREZ_API_KEY=  # Optional but recommended

# Monitoring (Optional)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<GENERATE_STRONG_PASSWORD>

# Build Information (Auto-generated)
BUILD_DATE=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
VCS_REF=$(git rev-parse --short HEAD)

# ===================================================================
# Security Notes:
# 1. Generate all passwords using: openssl rand -base64 32
# 2. Generate SECRET_KEY and JWT_SECRET using: openssl rand -hex 64
# 3. Update DOMAIN and URL values to match your actual domain
# 4. Never use default or weak passwords in production
# 5. Store this file securely and restrict access (chmod 600)
# ===================================================================
